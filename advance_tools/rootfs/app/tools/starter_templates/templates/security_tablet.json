{
  "id": "security_tablet",
  "name": "Security Tablet",
  "icon": "🔐",
  "description": "The panel you mount next to the front door. A full-height vault keypad, a radar status dial, every door, window and motion sensor, plus your cameras.",
  "tags": ["security", "keypad", "camera", "portrait"],
  "summary": [
    "Full-height Vault keypad — arm and disarm with a PIN",
    "Radar status dial and a siren strip",
    "Doors, windows and motion on status LEDs",
    "One or two live camera tiles",
    "Portrait layout, 800 × 1280"
  ],
  "canvas": { "w": 800, "h": 1280, "fit": "fit" },
  "theme": {
    "accent": "#ff6b81", "bg": "#07090f", "card": "#141a26",
    "text": "#e8edf7", "cols": 2, "radius": 14
  },

  "slots": [
    { "key": "front_door", "label": "Front door",
      "hint": "The door this tablet hangs next to.",
      "domain": "binary_sensor", "device_class": "door", "required": true,
      "keywords": ["front", "entry", "entrance", "main", "door"] },

    { "key": "back_door", "label": "Back door",
      "hint": "Optional.",
      "domain": "binary_sensor", "device_class": "door", "required": false,
      "keywords": ["back", "rear", "garden", "kitchen", "side", "patio"],
      "exclude": ["front"] },

    { "key": "window", "label": "Window",
      "hint": "Optional — any window contact.",
      "domain": "binary_sensor", "device_class": "window", "required": false,
      "keywords": ["window", "balcony", "terrace"] },

    { "key": "motion", "label": "Motion sensor",
      "hint": "Movement inside the house.",
      "domain": "binary_sensor", "device_class": "motion", "required": true,
      "keywords": ["motion", "movement", "presence", "pir", "hall", "living"] },

    { "key": "camera_front", "label": "Front camera",
      "hint": "The camera watching the entrance.",
      "domain": "camera", "required": true,
      "keywords": ["front", "door", "entry", "entrance", "porch", "gate"] },

    { "key": "camera_second", "label": "Second camera",
      "hint": "Optional — garden, driveway, back yard.",
      "domain": "camera", "required": false,
      "keywords": ["back", "garden", "yard", "driveway", "garage", "side"],
      "exclude": ["front"] },

    { "key": "garage_door", "label": "Garage door",
      "hint": "Optional.",
      "domain": "binary_sensor", "device_class": "garage_door",
      "required": false, "keywords": ["garage", "carport", "gate"] },

    { "key": "smoke", "label": "Smoke / gas alarm",
      "hint": "Optional.",
      "domain": "binary_sensor", "device_class": "smoke", "required": false,
      "keywords": ["smoke", "fire", "gas", "co", "carbon", "heat"] }
  ],

  "widgets": [
    { "type": "box", "text": "KEYPAD", "x": 32, "y": 160, "w": 380, "h": 600 },
    { "type": "box", "text": "STATUS", "x": 436, "y": 160, "w": 332, "h": 600 },
    { "type": "box", "text": "CAMERAS", "x": 32, "y": 784, "w": 736, "h": 300 },
    { "type": "box", "text": "ALERTS", "x": 32, "y": 1108, "w": 736, "h": 140 },

    { "type": "label", "text": "Home Security", "x": 32, "y": 20, "w": 420,
      "h": 40, "size": 28, "bold": true },
    { "type": "label", "text": "Arm before you leave, disarm when you get back",
      "x": 32, "y": 62, "w": 460, "h": 26, "size": 13, "color": "#8b98b8" },

    { "type": "clock", "skin": "clock-card", "x": 518, "y": 20, "w": 250,
      "h": 120 },

    { "type": "seckeypad", "skin": "sk-vault", "x": 72, "y": 200, "w": 300,
      "h": 520, "label": "Security", "modes": ["home", "away", "night"] },

    { "type": "seckeypad", "skin": "sk-radar", "x": 472, "y": 200, "w": 260,
      "h": 260, "label": "Status", "modes": ["home", "away", "night"] },

    { "type": "sensor", "skin": "led", "x": 472, "y": 490, "w": 190, "h": 52,
      "label": "Front door", "entity": "{{slot:front_door}}" },
    { "type": "sensor", "skin": "led", "x": 472, "y": 552, "w": 190, "h": 52,
      "label": "Back door", "entity": "{{slot:back_door}}" },
    { "type": "sensor", "skin": "led", "x": 472, "y": 614, "w": 190, "h": 52,
      "label": "Window", "entity": "{{slot:window}}" },
    { "type": "sensor", "skin": "led", "x": 472, "y": 676, "w": 190, "h": 52,
      "label": "Motion", "entity": "{{slot:motion}}" },

    { "type": "camera", "skin": "camera-live", "x": 72, "y": 824, "w": 320,
      "h": 200, "label": "Front door", "entity": "{{slot:camera_front}}" },
    { "type": "camera", "skin": "camera-tile", "x": 440, "y": 820, "w": 260,
      "h": 210, "label": "Second view", "entity": "{{slot:camera_second}}" },

    { "type": "seckeypad", "skin": "sk-siren", "x": 72, "y": 1123, "w": 340,
      "h": 110, "label": "Alarm", "modes": ["home", "away", "night"] },

    { "type": "sensor", "skin": "led", "x": 440, "y": 1129, "w": 190, "h": 52,
      "label": "Garage", "entity": "{{slot:garage_door}}" },
    { "type": "sensor", "skin": "led", "x": 440, "y": 1191, "w": 190, "h": 52,
      "label": "Smoke", "entity": "{{slot:smoke}}" }
  ]
}
